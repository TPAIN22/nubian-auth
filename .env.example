# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Clerk Auth ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Email ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Image Upload ────────────────────────────────────────────────────────────
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/<your-id>
IMAGEKIT_PUBLIC_KEY=public_...
IMAGEKIT_PRIVATE_KEY=private_...

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS (comma-separated list of allowed frontend origins) ─────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://www.nubian-sd.store,https://nubian-sd.store

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Affiliate / Referral ────────────────────────────────────────────────────
DEFAULT_COMMISSION_RATE=0.10
DEFAULT_DISCOUNT_RATE=0.10
AFFILIATE_BASE_URL=https://www.nubian-sd.store
MAX_REFERRAL_CLICKS_PER_IP=10
FRAUD_SCORE_THRESHOLD=80

# ─── Cron Jobs ───────────────────────────────────────────────────────────────
ENABLE_CRONS=false

# ─── MongoDB Connection Pool (optional) ──────────────────────────────────────
# MONGODB_MAX_POOL_SIZE=10
# MONGODB_MIN_POOL_SIZE=2

# ─── Redis / Queue ───────────────────────────────────────────────────────────
# Connection string for Redis (BullMQ). Required when ENABLE_QUEUE=true.
# Local dev: redis://localhost:6379
# Managed:   rediss://default:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# Optional namespace prefix — useful if multiple environments share one Redis.
# Effective queue names become "<REDIS_PREFIX>:nubian:notif:<channel>"
# REDIS_PREFIX=

# Master switch for the queue-based notification pipeline.
# false = synchronous fallback (current behavior, no Redis required).
# true  = enqueue notifications to BullMQ; workers do the actual delivery.
ENABLE_QUEUE=false

# ─── Workers ─────────────────────────────────────────────────────────────────
# Comma-separated roles for the worker process (only used when running
# `npm run worker`). Valid: push, email, sms, fanout, maintenance, all
WORKER_ROLES=push,email,fanout,maintenance

# Run workers inside the API process instead of a separate dyno.
# Convenient for single-dyno deploys; not recommended at scale.
RUN_WORKERS_INPROCESS=false
