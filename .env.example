# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Clerk Auth ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Email ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Image Upload ────────────────────────────────────────────────────────────
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/<your-id>
IMAGEKIT_PUBLIC_KEY=public_...
IMAGEKIT_PRIVATE_KEY=private_...

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS (comma-separated list of allowed frontend origins) ─────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://www.nubian-sd.store,https://nubian-sd.store

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Affiliate / Referral ────────────────────────────────────────────────────
DEFAULT_COMMISSION_RATE=0.10
DEFAULT_DISCOUNT_RATE=0.10
AFFILIATE_BASE_URL=https://www.nubian-sd.store
MAX_REFERRAL_CLICKS_PER_IP=10
FRAUD_SCORE_THRESHOLD=80

# ─── Cron Jobs ───────────────────────────────────────────────────────────────
ENABLE_CRONS=false

# ─── MongoDB Connection Pool (optional) ──────────────────────────────────────
# MONGODB_MAX_POOL_SIZE=10
# MONGODB_MIN_POOL_SIZE=2
